# ── Required ────────────────────────────────────────────────────────────────

# GitHub personal access token (needs repo + issues write permissions)
GITHUB_TOKEN=ghp_your_github_token_here

# OpenAI (or compatible) API key
OPENAI_API_KEY=sk-your_openai_api_key_here

# ── Optional ────────────────────────────────────────────────────────────────

# Base URL for an OpenAI-compatible API (default: https://api.openai.com/v1)
# Override to use local models (e.g. Ollama, LM Studio) or other providers
# OPENAI_BASE_URL=https://api.openai.com/v1

# Model to use for generation (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Absolute path to the local repository to scan for code context (default: .)
# Only used when RETRIEVE_MODE=local
# REPO_PATH=/path/to/your/repo

# File extensions to scan, comma-separated (default covers most languages)
# REPO_EXTENSIONS=.go,.ts,.js,.py,.java,.rs,.rb,.cs,.cpp,.c

# ── Retriever mode ───────────────────────────────────────────────────────────
# Controls where the agent reads code from.
#
# "local"  (default) — scans REPO_PATH on disk. Use for local development.
# "github"           — fetches files via the GitHub API. No local clone needed.
#                      Best for cloud deployments. Uses GITHUB_TOKEN.
#
# RETRIEVE_MODE=local
# RETRIEVE_MODE=github
#
# Branch to scan when RETRIEVE_MODE=github.
# Leave unset to use the repo's default branch (main/master) automatically.
# REPO_BRANCH=dev
#
# RETRIEVE_MODE=local
# RETRIEVE_MODE=github

# ── Webhook actions ──────────────────────────────────────────────────────────
# Comma-separated list of issue actions that trigger the agent (default: opened).
# opened   — new issue created
# edited   — issue title or body was changed
# reopened — closed issue was reopened
#
# WEBHOOK_ACTIONS=opened
# WEBHOOK_ACTIONS=opened,edited
# WEBHOOK_ACTIONS=opened,edited,reopened

# HTTP port the server listens on (default: 8080)
# PORT=8080

# ── OpenRouter (optional) ────────────────────────────────────────────────────
# Set OPENAI_BASE_URL + OPENAI_MODEL to use OpenRouter as the LLM provider:
#
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_MODEL=anthropic/claude-3.5-sonnet   # or any model on openrouter.ai/models
#
# Optional headers OpenRouter uses for analytics / rate-limit tiers:
# OPENROUTER_REFERER=https://github.com/your-org/product-agent
# OPENROUTER_TITLE=product-agent
